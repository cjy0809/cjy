<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.community.center.mapper.VenueMapper">

    <!-- 基本查询结果映射 -->
    <resultMap id="BaseResultMap" type="com.community.center.entity.Venue">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="capacity" property="capacity"/>
        <result column="equipment" property="equipment"/>
        <result column="open_time" property="openTime"/>
        <result column="close_time" property="closeTime"/>
        <result column="status" property="status"/>
        <result column="maintenance_date" property="maintenanceDate"/>
        <result column="maintenance_start_time" property="maintenanceStartTime"/>
        <result column="maintenance_end_time" property="maintenanceEndTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 基本查询字段 -->
    <sql id="Base_Column_List">
        id, name, description, capacity, equipment, open_time, close_time, status, 
        maintenance_date, maintenance_start_time, maintenance_end_time, 
        create_time, update_time
    </sql>

    <!-- 示例：根据ID查询 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" />
        FROM venue
        WHERE id = #{id}
    </select>

</mapper>